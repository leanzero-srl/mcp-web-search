{
  "name": "web-search-mcp-server",
  "version": "0.3.1",
  "description": "MCP server for web search with full page content extraction, search summaries, and single page content extraction",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "web-search-mcp": "./dist/index.js"
  },
  "scripts": {
    "bundle": "node scripts/bundle.js",
    "build": "tsc && node scripts/bundle.js && echo '✅ Build and Bundle complete: dist/index.js & dist/bundle.js'",
    "dev": "tsx watch src/index.ts",
    "start": "node ./dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "mcp",
    "web-search",
    "ai",
    "llm"
  ],
  "author": "Mark Russell",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrkrsl/web-search-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/client": "^2.0.0-alpha.2",
    "@modelcontextprotocol/node": "^2.0.0-alpha.2",
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@upstash/semantic-cache": "^1.0.5",
    "@upstash/vector": "^1.2.3",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "playwright": "^1.48.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
