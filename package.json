{
  "name": "web-search-mcp-server",
  "version": "0.3.1",
  "description": "MCP server for web search with full page content extraction, search summaries, and single page content extraction",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "web-search-mcp": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "bundle": "node scripts/bundle.js",
    "build": "npm run clean && tsc && node scripts/bundle.js && echo '✅ Build complete: dist/index.js (entry) + dist/bundle.cjs (single-file)'",
    "dev": "tsx watch src/index.ts",
    "start": "node ./dist/index.js",
    "start:http": "node ./dist/http-server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "mcp",
    "web-search",
    "ai",
    "llm"
  ],
  "author": "Mark Russell",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrkrsl/web-search-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@upstash/semantic-cache": "^1.0.5",
    "@upstash/vector": "^1.2.3",
    "argon2": "^0.41.1",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "p-limit": "^6.2.0",
    "p-retry": "^6.2.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.48.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cheerio": "^0.22.35",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "esbuild": "^0.25.5",
    "eslint": "^9.30.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
